# MongoDB Atlas
MONGODB_URI=
DB_NAME=modamall

# JWT
JWT_SECRET=
JWT_EXPIRES_IN=30d

# Optional bootstrap admin
ADMIN_BOOTSTRAP_EMAIL=
ADMIN_BOOTSTRAP_PASSWORD=
ADMIN_BOOTSTRAP_NAME=Admin
ADMIN_BOOTSTRAP_PHONE=

# Production web origins
CORS_ORIGINS=https://bazari.site,https://www.bazari.site

# Cross-origin auth cookies
COOKIE_SECURE=true
COOKIE_SAMESITE=none

# WhatsApp order line (international format, example: 994501234567)
WHATSAPP_ORDER_PHONE=

# Web Push
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@bazari.site

# Server
PORT=10000
