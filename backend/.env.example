# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/?appName=Cluster0
DB_NAME=modamall

# JWT
JWT_SECRET=change-this-to-a-long-random-string
JWT_EXPIRES_IN=30d

# CORS — Lovable frontend domain(s), comma-separated
CORS_ORIGINS=https://your-app.lovable.app,http://localhost:5173

# Cookie domain (leave empty for default)
COOKIE_SECURE=true
COOKIE_SAMESITE=none

# Web Push (optional — generate via: npx web-push generate-vapid-keys)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@example.com

# Server
PORT=10000
